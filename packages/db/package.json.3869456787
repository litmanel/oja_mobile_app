{
  "name": "@oja/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint \"src/**/*.ts*\"",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migrate.ts",
    "generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@oja/config": "workspace:^",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.22.7",
    "eslint": "^8.57.0",
    "tsx": "^4.15.2",
    "typescript": "^5.5.0"
  }
}
